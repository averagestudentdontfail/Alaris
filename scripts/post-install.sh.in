#!/bin/bash

# Alaris post-installation script
# This script is run after installation to set up the system

set -e

# Configuration
ALARIS_USER="@ALARIS_USER@"
ALARIS_GROUP="@ALARIS_GROUP@"
ALARIS_CONFIG_DIR="@ALARIS_CONFIGDIR@"
ALARIS_DATA_DIR="@ALARIS_DATADIR@"
ALARIS_LOG_DIR="@ALARIS_LOGDIR@"

# Create necessary directories
mkdir -p "${ALARIS_CONFIG_DIR}"
mkdir -p "${ALARIS_DATA_DIR}"
mkdir -p "${ALARIS_LOG_DIR}"

# Set permissions
chown -R "${ALARIS_USER}:${ALARIS_GROUP}" "${ALARIS_CONFIG_DIR}"
chown -R "${ALARIS_USER}:${ALARIS_GROUP}" "${ALARIS_DATA_DIR}"
chown -R "${ALARIS_USER}:${ALARIS_GROUP}" "${ALARIS_LOG_DIR}"

chmod 750 "${ALARIS_CONFIG_DIR}"
chmod 750 "${ALARIS_DATA_DIR}"
chmod 750 "${ALARIS_LOG_DIR}"

# Reload systemd if available
if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload
fi

echo "Alaris post-installation completed successfully" 