<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <AssemblyName>Alaris.Lean</AssemblyName>
    <RootNamespace>Alaris</RootNamespace>
    <Nullable>enable</Nullable>
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <ConcurrentGarbageCollection>true</ConcurrentGarbageCollection>
    <RetainVMGarbageCollection>true</RetainVMGarbageCollection>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <BaseOutputPath>bin</BaseOutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='Release'">
    <Optimize>true</Optimize>
    <DebugType>portable</DebugType>
    <DebugSymbols>true</DebugSymbols>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='Debug'">
    <Optimize>false</Optimize>
    <DebugType>full</DebugType>
    <DebugSymbols>true</DebugSymbols>
  </PropertyGroup>

  <ItemGroup>
    <!-- Lean Packages -->
    <PackageReference Include="QuantConnect.Lean" Version="2.5.16910" />
    <PackageReference Include="QuantConnect.Brokerages.InteractiveBrokers" Version="2.5.16910" />
    
    <!-- Packages for YAML and JSON configuration parsing -->
    <PackageReference Include="YamlDotNet" Version="15.1.2" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />

    <!-- System.CommandLine is used for robust argument parsing -->
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />

    <!-- 
      REMOVED: The explicit reference to System.IO.MemoryMappedFiles.
      This functionality is built into the .NET 9 SDK and is no longer needed
      as a separate package. Keeping it causes the NU1102 version conflict error.
    -->
    <!-- <PackageReference Include="System.IO.MemoryMappedFiles" Version="8.0.0" /> -->
  </ItemGroup>

  <ItemGroup>
    <!-- This ensures your master YAML/JSON configs are copied to the output directory -->
    <None Update="config\*.yaml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="config\*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Suppress platform-specific warnings for cross-platform code -->
  <PropertyGroup>
    <NoWarn>$(NoWarn);CA1416</NoWarn>
  </PropertyGroup>

</Project>
