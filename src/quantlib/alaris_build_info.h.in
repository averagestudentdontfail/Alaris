// src/quantlib/alaris_build_info.h.in
// Auto-generated build information for Alaris
// This file is configured by CMake - do not edit manually

#pragma once

#include <string>
#include <cstdint>

namespace Alaris {
namespace BuildInfo {

// Version information
constexpr const char* VERSION = "@PROJECT_VERSION@";
constexpr int VERSION_MAJOR = @PROJECT_VERSION_MAJOR@;
constexpr int VERSION_MINOR = @PROJECT_VERSION_MINOR@;
constexpr int VERSION_PATCH = @PROJECT_VERSION_PATCH@;

// Build information
constexpr const char* BUILD_TYPE = "@CMAKE_BUILD_TYPE@";
constexpr const char* BUILD_TIMESTAMP = "@BUILD_TIMESTAMP@";
constexpr const char* BUILD_DATE = __DATE__;
constexpr const char* BUILD_TIME = __TIME__;

// Compiler information
constexpr const char* COMPILER_ID = "@CMAKE_CXX_COMPILER_ID@";
constexpr const char* COMPILER_VERSION = "@CMAKE_CXX_COMPILER_VERSION@";
constexpr const char* CXX_STANDARD = "C++@CMAKE_CXX_STANDARD@";

// Platform information
constexpr const char* SYSTEM_NAME = "@CMAKE_SYSTEM_NAME@";
constexpr const char* SYSTEM_VERSION = "@CMAKE_SYSTEM_VERSION@";
constexpr const char* SYSTEM_PROCESSOR = "@CMAKE_SYSTEM_PROCESSOR@";

// Git information (if available)
constexpr const char* GIT_COMMIT_HASH = "@GIT_COMMIT_HASH@";
constexpr const char* GIT_BRANCH = "@GIT_BRANCH@";
constexpr const char* GIT_TAG = "@GIT_TAG@";
constexpr bool GIT_DIRTY = @GIT_DIRTY@;

// Feature flags
constexpr bool HAS_QUANTLIB = @QUANTLIB_TARGET_EXISTS@;
constexpr bool HAS_YAML_CPP = @YAML_CPP_TARGET_EXISTS@;
constexpr bool HAS_BOOST_SYSTEM = @Boost_FOUND@;
constexpr bool HAS_OPENMP = @OpenMP_CXX_FOUND@;

// Platform capabilities
constexpr bool HAS_SHARED_MEMORY = @PLATFORM_HAS_SHARED_MEMORY@;
constexpr bool HAS_REALTIME = @PLATFORM_HAS_REALTIME@;
constexpr bool HAS_CPU_AFFINITY = @PLATFORM_HAS_CPU_AFFINITY@;
constexpr bool HAS_HUGE_PAGES = @PLATFORM_HAS_HUGE_PAGES@;

// Architecture features
constexpr bool IS_X86_64 = @ARCH_X86_64@;
constexpr bool IS_ARM64 = @ARCH_ARM64@;
constexpr bool IS_ARM32 = @ARCH_ARM32@;
constexpr bool HAS_AVX2 = @HAVE_AVX2@;
constexpr bool HAS_FMA = @HAVE_FMA@;

// Build configuration
constexpr bool IS_DEBUG_BUILD = 
#ifdef DEBUG_BUILD
    true;
#else
    false;
#endif

constexpr bool IS_RELEASE_BUILD = 
#ifdef RELEASE_BUILD
    true;
#else
    false;
#endif

// Dependencies versions
constexpr const char* QUANTLIB_VERSION = "@QUANTLIB_VERSION@";
constexpr const char* YAML_CPP_VERSION = "@YAML_CPP_VERSION@";
constexpr const char* BOOST_VERSION = "@Boost_VERSION@";

// Build paths (for development)
constexpr const char* SOURCE_DIR = "@CMAKE_SOURCE_DIR@";
constexpr const char* BINARY_DIR = "@CMAKE_BINARY_DIR@";
constexpr const char* INSTALL_PREFIX = "@CMAKE_INSTALL_PREFIX@";

// Function to get build information as a formatted string
inline std::string getBuildInfoString() {
    std::string info;
    info += "Alaris Trading System\n";
    info += "Version: " + std::string(VERSION) + "\n";
    info += "Build Type: " + std::string(BUILD_TYPE) + "\n";
    info += "Build Date: " + std::string(BUILD_DATE) + " " + std::string(BUILD_TIME) + "\n";
    info += "Compiler: " + std::string(COMPILER_ID) + " " + std::string(COMPILER_VERSION) + "\n";
    info += "Platform: " + std::string(SYSTEM_NAME) + " " + std::string(SYSTEM_PROCESSOR) + "\n";
    info += "C++ Standard: " + std::string(CXX_STANDARD) + "\n";
    
    if (strlen(GIT_COMMIT_HASH) > 0) {
        info += "Git Commit: " + std::string(GIT_COMMIT_HASH);
        if (GIT_DIRTY) {
            info += " (dirty)";
        }
        info += "\n";
        if (strlen(GIT_BRANCH) > 0) {
            info += "Git Branch: " + std::string(GIT_BRANCH) + "\n";
        }
    }
    
    info += "\nFeatures:\n";
    info += "  QuantLib: " + std::string(HAS_QUANTLIB ? "Yes" : "No") + "\n";
    info += "  Shared Memory: " + std::string(HAS_SHARED_MEMORY ? "Yes" : "No") + "\n";
    info += "  Real-time: " + std::string(HAS_REALTIME ? "Yes" : "No") + "\n";
    info += "  CPU Affinity: " + std::string(HAS_CPU_AFFINITY ? "Yes" : "No") + "\n";
    
    if (IS_X86_64) {
        info += "  AVX2: " + std::string(HAS_AVX2 ? "Yes" : "No") + "\n";
        info += "  FMA: " + std::string(HAS_FMA ? "Yes" : "No") + "\n";
    }
    
    return info;
}

// Function to get version as uint32_t for easy comparison
constexpr uint32_t getVersionNumber() {
    return (VERSION_MAJOR << 16) | (VERSION_MINOR << 8) | VERSION_PATCH;
}

// Function to check if this is a development build
constexpr bool isDevelopmentBuild() {
    return IS_DEBUG_BUILD || GIT_DIRTY;
}

// Function to get short version string
inline std::string getShortVersionString() {
    std::string version = std::string(VERSION);
    if (strlen(GIT_COMMIT_HASH) > 7) {
        version += "-" + std::string(GIT_COMMIT_HASH).substr(0, 7);
    }
    if (GIT_DIRTY) {
        version += "-dirty";
    }
    return version;
}

} // namespace BuildInfo
} // namespace Alaris