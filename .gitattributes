# Alaris Trading System - Git Attributes Configuration

# Set default behavior to automatically normalize line endings
* text=auto

# Source code files
*.cpp text eol=lf
*.c text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cc text eol=lf
*.cxx text eol=lf
*.hxx text eol=lf

# C# source files
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf

# CMake files
CMakeLists.txt text eol=lf
*.cmake text eol=lf
*.cmake.in text eol=lf

# Configuration files
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.conf text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
LICENSE text eol=lf
README* text eol=lf
CHANGELOG* text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.pl text eol=lf
*.ps1 text eol=crlf

# Docker files
Dockerfile* text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf

# CI/CD files
.github/workflows/*.yml text eol=lf
.gitlab-ci.yml text eol=lf
*.jenkinsfile text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.xml text eol=lf

# Data files
*.csv text eol=lf
*.tsv text eol=lf
*.sql text eol=lf

# Archive files (binary)
*.zip binary
*.tar binary
*.tar.gz binary
*.tar.bz2 binary
*.tar.xz binary
*.7z binary
*.rar binary

# Executable files (binary)
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.lib binary

# Images (binary)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.bmp binary
*.tiff binary

# Office documents (binary)
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.pdf binary

# Font files (binary)
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Audio/Video files (binary)
*.mp3 binary
*.mp4 binary
*.avi binary
*.mov binary
*.wmv binary
*.wav binary
*.flac binary

# Git attributes for language detection
*.cpp linguist-language=C++
*.h linguist-language=C++
*.hpp linguist-language=C++
*.cs linguist-language=C#
*.cmake linguist-language=CMake
CMakeLists.txt linguist-language=CMake

# Mark vendored code to exclude from language statistics
external/* linguist-vendored
third-party/* linguist-vendored
vendor/* linguist-vendored
deps/* linguist-vendored

# Mark generated files
*_generated.* linguist-generated
*.pb.* linguist-generated
build/* linguist-generated

# Mark documentation files
docs/* linguist-documentation
*.md linguist-documentation

# Large file handling (Git LFS)
# Uncomment if using Git LFS for large files
# *.bin filter=lfs diff=lfs merge=lfs -text
# *.dat filter=lfs diff=lfs merge=lfs -text
# *.db filter=lfs diff=lfs merge=lfs -text

# Diff settings for specific files
*.cpp diff=cpp
*.h diff=cpp
*.hpp diff=cpp
*.cs diff=csharp
*.cmake diff=cmake

# Merge drivers for specific files
*.md merge=union
CHANGELOG* merge=union

# Export ignore (files not included in git archive)
.gitattributes export-ignore
.gitignore export-ignore
.github/ export-ignore
.vscode/ export-ignore
.idea/ export-ignore
.clang-format export-ignore
.clang-tidy export-ignore

# File encoding
*.cpp encoding=UTF-8
*.h encoding=UTF-8
*.cs encoding=UTF-8
*.cmake encoding=UTF-8
*.md encoding=UTF-8

# Working tree encoding
*.sln working-tree-encoding=UTF-8
*.csproj working-tree-encoding=UTF-8