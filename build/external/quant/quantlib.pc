prefix=/opt/alaris
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: QuantLib
Description: The free/open-source library for quantitative finance.
Version: 1.39.0-dev
Cflags: -I${prefix}/include    
Libs: -L${exec_prefix}/lib -lQuantLib  /usr/lib/x86_64-linux-gnu/libpthread.a
